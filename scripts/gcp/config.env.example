# Copy to scripts/gcp/config.env and edit:
#   cp scripts/gcp/config.env.example scripts/gcp/config.env

# Required — create a NEW GCP project for IKR (separate from financetracketserver)
GCP_PROJECT_ID=your-ikr-project-id
GCP_REGION=asia-southeast1

# GCS bucket for ikr.db (created by bootstrap)
GCS_DATA_BUCKET=your-ikr-project-id-ikr-data

# Artifact Registry repo name (created by bootstrap)
AR_REPO=individual-ikr

# Image name in Artifact Registry
IKR_IMAGE=individual-ikr

# Runtime
TZ=Asia/Kolkata
USE_SECRET_MANAGER=1
GCP_SECRET_PREFIX=ikr-

# Service account ids (created by bootstrap)
RUNNER_SA=ikr-runner
SCHEDULER_SA=ikr-scheduler

# Cloud Scheduler wakes every 30 min; admin picks 30m/1h/3h/6h in app Settings (ikr.db).
IKR_SCHEDULER_CRON='*/30 * * * *'

# Streamlit: set to 1 to allow public URL (app has its own login)
STREAMLIT_PUBLIC=1
STREAMLIT_MIN_INSTANCES=0
